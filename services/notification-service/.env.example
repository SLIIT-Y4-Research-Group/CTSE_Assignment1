PORT=3000
SERVICE_NAME=notification-service
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/notifydb

# Notify.lk SMS
NOTIFY_LK_URL=https://app.notify.lk/api/v1/send
NOTIFY_LK_USER_ID=your_user_id
NOTIFY_LK_API_KEY=your_api_key
NOTIFY_LK_SENDER_ID=your_sender_id

# SMTP Email (host-based)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_username
SMTP_PASS=your_password
MAIL_FROM=notifications@example.com

# Email service (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Your App <your_email@gmail.com>
